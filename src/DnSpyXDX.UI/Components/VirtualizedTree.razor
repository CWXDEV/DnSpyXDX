@inject IDecompilerBackend Backend
@inject IJSRuntime JS

<div class="explorer-tree" @ref="viewport">
  @if (Assemblies.Count == 0)
  {
    <div class="empty">@EmptyMessage</div>
  }
  else
  {
    <Virtualize Items="visible" Context="item" ItemSize="RowHeight" OverscanCount="12">
      <button @key="item.Node.Id" class="tree-row @(IsSelected(item.Node) ? "selected" : null)" style="--depth:@item.Depth" title="@(item.Tooltip ?? item.Node.Detail)" @onclick="e => SelectAsync(item.Node, e)" @oncontextmenu="e => OpenContextMenuAsync(item.Node, e)" @oncontextmenu:preventDefault="@(item.Node.Kind == TreeNodeKind.Assembly)" @oncontextmenu:stopPropagation="@(item.Node.Kind == TreeNodeKind.Assembly)">
        <span class="chevron" @onclick="() => ToggleAsync(item.Node)" @onclick:stopPropagation="true">@(item.Node.HasChildren ? (expanded.Contains(item.Node.Id) ? "▾" : "▸") : "")</span>@if (ShowIcon(item.Node.Kind)) { <span class="node-icon @item.Node.Kind.ToString().ToLowerInvariant()">@Icon(item.Node.Kind)</span> }@if (item.Node.Visibility is not null && item.Node.Kind != TreeNodeKind.Type) { <span class="meta-visibility">@item.Node.Visibility</span> }@if (item.Node.TypeDisplay is not null) { <span class="meta-type meta-type-@item.Node.TypeClassification">@item.Node.TypeDisplay</span> }<span class="meta-name meta-@item.Node.NameClassification">@item.Node.Name</span>@if (item.Node.Detail is not null) { <small>@item.Node.Detail</small> }
      </button>
    </Virtualize>
  }
</div>

@code {
  private const int RowHeight = 26;
  [Parameter, EditorRequired] public IReadOnlyList<AssemblyDescriptor> Assemblies { get; set; } = [];
  [Parameter] public string EmptyMessage { get; set; } = "Open a managed .dll or .exe to begin.";
  [Parameter] public EventCallback<NavigationRequest> OnOpen { get; set; }
  [Parameter] public EventCallback<NodeId> OnOpenReference { get; set; }
  [Parameter] public EventCallback<(MouseEventArgs Event, NodeId Node)> OnContextMenu { get; set; }
  [Parameter] public IReadOnlySet<NodeId>? ExpandedPath { get; set; }
  [Parameter] public SymbolId? SelectedSymbol { get; set; }
  [Parameter] public NodeId? SelectedNode { get; set; }
  [Parameter] public int SelectionVersion { get; set; }
  [Parameter] public int CollapseVersion { get; set; }

  private ElementReference viewport;
  private readonly Dictionary<NodeId, IReadOnlyList<TreeNodeDescriptor>> children = [];
  private readonly HashSet<NodeId> expanded = [];
  private IReadOnlyList<FlatNode> roots = [];
  private ICollection<FlatNode> visible = Array.Empty<FlatNode>();
  private int handledCollapseVersion;
  private int handledSelectionVersion = -1;
  private HashSet<NodeId> appliedPath = [];
  private bool scrollToSelection;

  protected override async Task OnParametersSetAsync()
  {
    roots = Assemblies.Select(assembly => new FlatNode(new TreeNodeDescriptor(assembly.RootNode, assembly.Name, TreeNodeKind.Assembly, true, Detail: assembly.TargetFramework), 0, $"Loaded from: {Path.GetDirectoryName(assembly.Path)}")).ToArray();
    var validSessions = Assemblies.Select(assembly => assembly.SessionId).ToHashSet();
    foreach (var key in children.Keys.Where(key => !validSessions.Contains(key.SessionId)).ToArray()) children.Remove(key);
    expanded.RemoveWhere(key => !validSessions.Contains(key.SessionId));
    if (CollapseVersion > 0 && CollapseVersion != handledCollapseVersion)
    {
      handledCollapseVersion = CollapseVersion;
      expanded.Clear();
      handledSelectionVersion = SelectionVersion;
      appliedPath = ExpandedPath?.ToHashSet() ?? [];
    }
    RebuildVisible();
    var pathChanged = ExpandedPath is not null && !appliedPath.SetEquals(ExpandedPath);
    if (SelectionVersion != handledSelectionVersion || pathChanged)
    {
      handledSelectionVersion = SelectionVersion;
      await ExpandPathAsync();
      appliedPath = ExpandedPath?.ToHashSet() ?? [];
      scrollToSelection = true;
    }
  }

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (!scrollToSelection) return;
    scrollToSelection = false;
    var index = visible.ToList().FindIndex(item => IsSelected(item.Node));
    if (index >= 0) await JS.InvokeVoidAsync("dnSpyXdx.scrollTreeToIndex", viewport, index, RowHeight);
  }

  private async Task ExpandPathAsync()
  {
    if (ExpandedPath is null || ExpandedPath.Count == 0) return;
    while (true)
    {
      var item = visible.FirstOrDefault(candidate => candidate.Node.HasChildren && ExpandedPath.Contains(candidate.Node.Id) && !expanded.Contains(candidate.Node.Id));
      if (item is null) break;
      await LoadChildrenAsync(item.Node);
      expanded.Add(item.Node.Id);
      RebuildVisible();
    }
  }

  private async Task ToggleAsync(TreeNodeDescriptor node)
  {
    if (!node.HasChildren) return;
    if (!expanded.Remove(node.Id))
    {
      await LoadChildrenAsync(node);
      expanded.Add(node.Id);
    }
    RebuildVisible();
  }

  private async Task LoadChildrenAsync(TreeNodeDescriptor node)
  {
    if (!children.ContainsKey(node.Id)) children[node.Id] = await Backend.GetChildrenAsync(node.Id);
  }

  private void RebuildVisible()
  {
    var flattened = new List<FlatNode>();
    foreach (var root in roots) Append(root, flattened);
    visible = flattened;
    StateHasChanged();
  }

  private void Append(FlatNode item, List<FlatNode> flattened)
  {
    flattened.Add(item);
    if (!expanded.Contains(item.Node.Id) || !children.TryGetValue(item.Node.Id, out var descendants)) return;
    foreach (var child in descendants) Append(new FlatNode(child, item.Depth + 1), flattened);
  }

  private async Task SelectAsync(TreeNodeDescriptor node, MouseEventArgs e)
  {
    if (node.Symbol is { } symbol) await OnOpen.InvokeAsync(new NavigationRequest(symbol, e.CtrlKey, node.Kind, node.Name));
    else if (node.Kind == TreeNodeKind.Reference) await OnOpenReference.InvokeAsync(node.Id);
    else await ToggleAsync(node);
  }

  private Task OpenContextMenuAsync(TreeNodeDescriptor node, MouseEventArgs e) => node.Kind == TreeNodeKind.Assembly ? OnContextMenu.InvokeAsync((e, node.Id)) : Task.CompletedTask;
  private bool IsSelected(TreeNodeDescriptor node) => node.Id == SelectedNode || node.Symbol is { } symbol && symbol == SelectedSymbol;
  private static bool ShowIcon(TreeNodeKind kind) => kind is TreeNodeKind.Assembly or TreeNodeKind.Group or TreeNodeKind.Reference or TreeNodeKind.Resource;
  private static string Icon(TreeNodeKind kind) => kind switch { TreeNodeKind.Assembly => "◈", TreeNodeKind.Namespace => "N", TreeNodeKind.Type => "C", TreeNodeKind.Method or TreeNodeKind.Constructor => "M", TreeNodeKind.Property => "P", TreeNodeKind.Field => "F", TreeNodeKind.Event => "E", TreeNodeKind.Reference => "↗", TreeNodeKind.Resource => "◆", _ => "▦" };
  private sealed record FlatNode(TreeNodeDescriptor Node, int Depth, string? Tooltip = null);
}
