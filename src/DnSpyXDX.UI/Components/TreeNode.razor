@inject IDecompilerBackend Backend
@inject IJSRuntime JS
<div class="tree-item depth-@Depth">
  <button class="tree-row @(IsSelected ? "selected" : null)" title="@(Tooltip ?? Node.Detail)" @onclick="SelectAsync" @oncontextmenu="OpenContextMenuAsync" @oncontextmenu:preventDefault="@(Node.Kind == TreeNodeKind.Assembly)" @oncontextmenu:stopPropagation="@(Node.Kind == TreeNodeKind.Assembly)" @ref="row">
    <span class="chevron" @onclick="ToggleAsync" @onclick:stopPropagation="true">@(Node.HasChildren ? (expanded ? "▾" : "▸") : "")</span><span class="node-icon @Node.Kind.ToString().ToLowerInvariant()">@Icon</span>@if (Node.Visibility is not null) { <span class="meta-visibility">@Node.Visibility</span> }@if (Node.TypeDisplay is not null) { <span class="meta-type meta-type-@Node.TypeClassification">@Node.TypeDisplay</span> }<span class="meta-name meta-@Node.NameClassification">@Node.Name</span>@if (Node.Detail is not null) { <small>@Node.Detail</small> }
  </button>
  @if (expanded) { @foreach (var child in children) { <TreeNode @key="child.Id" Node="child" Depth="@(Depth + 1)" OnOpen="OnOpen" OnOpenReference="OnOpenReference" ExpandedPath="ExpandedPath" SelectedSymbol="SelectedSymbol" SelectedNode="SelectedNode" SelectionVersion="SelectionVersion" CollapseVersion="CollapseVersion" /> } }
</div>
@code {
  [Parameter, EditorRequired] public TreeNodeDescriptor Node { get; set; } = null!;
  [Parameter] public int Depth { get; set; }
  [Parameter] public EventCallback<NavigationRequest> OnOpen { get; set; }
  [Parameter] public EventCallback<NodeId> OnOpenReference { get; set; }
  [Parameter] public EventCallback<MouseEventArgs> OnContextMenu { get; set; }
  [Parameter] public string? Tooltip { get; set; }
  [Parameter] public IReadOnlySet<NodeId>? ExpandedPath { get; set; }
  [Parameter] public SymbolId? SelectedSymbol { get; set; }
  [Parameter] public NodeId? SelectedNode { get; set; }
  [Parameter] public int SelectionVersion { get; set; }
  [Parameter] public int CollapseVersion { get; set; }
  private bool expanded; private bool manuallyCollapsed; private IReadOnlyList<TreeNodeDescriptor> children = [];
  private int handledCollapseVersion;
  private ElementReference row;
  private bool wasSelected;
  private int handledSelectionVersion;
  private bool IsSelected => Node.Id == SelectedNode || Node.Symbol is { } symbol && symbol == SelectedSymbol;
  private string Icon => Node.Kind switch { TreeNodeKind.Assembly => "◈", TreeNodeKind.Namespace => "N", TreeNodeKind.Type => "C", TreeNodeKind.Method or TreeNodeKind.Constructor => "M", TreeNodeKind.Property => "P", TreeNodeKind.Field => "F", TreeNodeKind.Event => "E", TreeNodeKind.Reference => "↗", TreeNodeKind.Resource => "◆", _ => "▦" };
  private async Task SelectAsync(MouseEventArgs e) { if (Node.Symbol is { } symbol) await OnOpen.InvokeAsync(new NavigationRequest(symbol, e.CtrlKey, Node.Kind, Node.Name)); else if (Node.Kind == TreeNodeKind.Reference) await OnOpenReference.InvokeAsync(Node.Id); else await ToggleAsync(); }
  private Task OpenContextMenuAsync(MouseEventArgs e) => Node.Kind == TreeNodeKind.Assembly ? OnContextMenu.InvokeAsync(e) : Task.CompletedTask;
  private async Task ToggleAsync() { if (!Node.HasChildren) return; expanded = !expanded; manuallyCollapsed = !expanded; if (expanded && children.Count == 0) children = await Backend.GetChildrenAsync(Node.Id); }
  protected override async Task OnParametersSetAsync()
  {
    if (Node.HasChildren && CollapseVersion > 0 && CollapseVersion != handledCollapseVersion)
    {
      handledCollapseVersion = CollapseVersion;
      expanded = false;
      manuallyCollapsed = true;
    }
    var inPath = ExpandedPath?.Contains(Node.Id) == true;
    if (!inPath) manuallyCollapsed = false;
    if (Node.HasChildren && inPath && !manuallyCollapsed) { expanded = true; if (children.Count == 0) children = await Backend.GetChildrenAsync(Node.Id); }
  }
  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    // Reveal a newly selected symbol once. Repeating this on every workspace/status render makes
    // the explorer fight the user when they deliberately scroll away from the selected node.
    var becameSelected = IsSelected && (!wasSelected || SelectionVersion != handledSelectionVersion);
    wasSelected = IsSelected;
    if (becameSelected)
    {
      handledSelectionVersion = SelectionVersion;
      await JS.InvokeVoidAsync("dnSpyXdx.scrollTreeNodeIntoView", row);
    }
  }
}
