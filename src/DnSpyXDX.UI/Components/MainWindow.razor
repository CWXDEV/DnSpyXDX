@implements IDisposable
@inject IDecompilerBackend Backend
@inject IProjectExportService Exporter
@inject IFileDialogService Dialogs
@inject WorkspaceState Workspace
@inject IJSRuntime JS
@inject IWorkspaceSessionService Session
@inject IApplicationZoomService Zoom
@inject IApplicationLifetime ApplicationLifetime
@inject SourceViewStateStore SourceViewStates
@inject SourcePresentationCache SourceCache
@inject RuntimeLoggingSettings LoggingSettings

<div class="app-shell">
  <header class="toolbar">
    <div class="app-menu">
      <button type="button" class="hamburger" title="Application menu" aria-label="Application menu" aria-expanded="@menuOpen" @onclick="ToggleMenu" @onclick:stopPropagation><span></span><span></span><span></span></button>
      @if (menuOpen) {
        <div class="menu-dismiss" @onclick="CloseMenu"></div>
        <div class="menu-popup">
          <div class="menu-identity"><img src="_content/DnSpyXDX.UI/images/dnspyxdx-logo.webp" alt=""><span>DnSpyXDX</span></div>
          <button @onclick="OpenFromMenuAsync" disabled="@Workspace.IsBusy"><span>Open assembly</span></button>
          <button @onclick="ExportFromMenuAsync" disabled="@(Workspace.IsBusy || Backend.Assemblies.Count == 0)"><span>Extract solution</span></button>
          <button @onclick="UnloadAllAsync" disabled="@(Workspace.IsBusy || Backend.Assemblies.Count == 0)"><span>Unload all assemblies</span></button>
          <div class="menu-separator" role="separator"></div>
          <button @onclick="OpenSettings"><span>Settings</span></button>
          <button @onclick="Exit"><span>Exit</span></button>
        </div>
      }
    </div>
    <div class="toolbar-navigation" aria-label="Document navigation">
      <button class="toolbar-icon" title="Back (Alt+Left)" aria-label="Back" disabled="@(Workspace.ActiveTab?.CanGoBack != true)" @onclick="() => NavigateHistory(false)">←</button>
      <button class="toolbar-icon" title="Forward (Alt+Right)" aria-label="Forward" disabled="@(Workspace.ActiveTab?.CanGoForward != true)" @onclick="() => NavigateHistory(true)">→</button>
    </div>
    <button class="toolbar-icon search-toolbar-button @(searchOpen ? "active" : null)" title="@(searchOpen ? "Close search" : "Open search")" aria-label="@(searchOpen ? "Close search" : "Open search")" aria-pressed="@searchOpen" disabled="@(Backend.Assemblies.Count == 0)" @onclick="ToggleSearchPanel">
      <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.5" cy="10.5" r="6.5"></circle><path d="m15.5 15.5 5 5"></path></svg>
    </button>
  </header>
  <main>
    <div class="explorer-pane" @ref="explorer" style="width:@($"{explorerWidth}px")">
      <aside class="explorer">
        <header class="explorer-header">
          <div class="panel-title">ASSEMBLIES</div>
          <div class="tree-actions" aria-label="Assembly tree controls">
            <button class="tree-action" title="Collapse all nodes" aria-label="Collapse all nodes" disabled="@(Backend.Assemblies.Count == 0)" @onclick="CollapseAllNodes">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m7 15 5-5 5 5"></path><path d="m7 10 5-5 5 5"></path></svg>
            </button>
          </div>
        </header>
        <div class="explorer-tree">
          @if (Backend.Assemblies.Count == 0) { <div class="empty">@(restoring ? "Restoring assembly tree…" : "Open a managed .dll or .exe to begin.")</div> }
          @foreach (var assembly in Backend.Assemblies) { <TreeNode @key="assembly.RootNode" Node="@(new TreeNodeDescriptor(assembly.RootNode, assembly.Name, TreeNodeKind.Assembly, true, Detail: assembly.TargetFramework))" Tooltip="@($"Loaded from: {Path.GetDirectoryName(assembly.Path)}")" OnOpen="OpenTreeSymbolAsync" OnOpenReference="OpenReferenceAsync" OnContextMenu="e => OpenAssemblyContextMenu(e, assembly)" ExpandedPath="revealedPath" SelectedSymbol="selectedSymbol" SelectedNode="selectedNode" SelectionVersion="treeSelectionVersion" CollapseVersion="treeCollapseVersion" /> }
        </div>
      </aside>
      <div class="explorer-resizer" title="Drag to resize assembly tree"></div>
    </div>
    <section class="document-area">
      <nav class="tabs">
        @foreach (var tab in Workspace.Tabs) { <button class="tab @(Workspace.ActiveTabId == tab.Id ? "active" : null)" @onclick="() => Workspace.Activate(tab.Id)" @onmouseup="e => TabMouseUp(e, tab.Id)" @onmousedown:preventDefault="true"><span>@tab.Title</span><small>@(tab.IsLoading ? "Decompiling…" : tab.AssemblyName)</small><i @onclick:stopPropagation @onclick="() => CloseTab(tab.Id)">×</i></button> }
      </nav>
      <div class="document-content">
        @if (restoring && Workspace.ActiveTab is null) { <div class="decompiling-panel"><span class="decompiling-spinner"></span><strong>Restoring session…</strong><small>Loading assemblies and rebuilding the assembly tree.</small></div> }
        else if (Workspace.ActiveTab is { IsLoading: true } loading) { <div class="decompiling-panel"><span class="decompiling-spinner"></span><strong>Decompiling @loading.Title…</strong><small>Restoring saved source after the assembly tree has loaded.</small></div> }
        else if (Workspace.ActiveTab is { Error: not null } failed) { <div class="decompiling-panel error"><strong>Decompilation failed</strong><small>@failed.Error</small></div> }
        else if (Workspace.ActiveTab is { } active) { <SourceView TabId="active.Id" Document="active.Document" OnNavigate="NavigateFromSourceAsync" /> }
      </div>
      @if (searchOpen) {
        <section class="search-panel" @ref="searchPanel" style="height:@($"{searchPanelHeight}px")">
          <div class="search-resizer" title="Drag to resize search results"></div>
          <header><strong>Search</strong><input @ref="searchInput" @bind="query" @bind:event="oninput" @bind:after="QueueSearch" @onkeydown="SearchKey" placeholder="Type or member name…" /><select @bind="searchKind" @bind:after="LayoutOptionChanged" title="Member type"><option value="All">All members</option><option value="Type">Types</option><option value="Method">Methods</option><option value="Field">Fields</option><option value="Property">Properties</option><option value="Event">Events</option></select><select @bind="searchScope" @bind:after="LayoutOptionChanged" title="Assembly scope"><option value="All">All assemblies</option><option value="Selected" disabled="@(SelectedAssemblyMvid is null)">Selected assembly</option></select><button class="run-search" @onclick="SearchAsync">Search</button><small>@results.Count result@(results.Count == 1 ? "" : "s")</small><button class="close-search" title="Close search" @onclick="CloseSearch">×</button></header>
          <div class="search-results-header" role="row">
            <span role="columnheader">Type</span><span role="columnheader">Name</span><span role="columnheader">Namespace</span><span role="columnheader">Assembly</span>
          </div>
          <div class="search-results">
            @if (results.Count == 0) { <div class="no-results">@(string.IsNullOrWhiteSpace(query) ? "Type a name to search across open assemblies." : "No matching types or members.")</div> }
            @foreach (var result in results) {
              <button class="search-result" @onclick="e => OpenSearchResultAsync(result, e.CtrlKey)">
                <span class="result-kind result-@result.Kind.ToLowerInvariant()">@result.Kind</span><span class="result-name">@result.Name</span><span class="result-namespace">@result.Namespace</span><span class="result-assembly">@result.AssemblyName</span>
              </button>
            }
          </div>
        </section>
      }
    </section>
  </main>
  <footer><span class="status-dot @(Workspace.IsBusy ? "busy" : null)"></span>@Workspace.Status</footer>
  @if (contextAssembly is not null)
  {
    <div class="context-menu-dismiss" @onclick="CloseAssemblyContextMenu" @oncontextmenu:preventDefault></div>
    <div class="assembly-context-menu" style="--context-x:@(contextMenuX)px;--context-y:@(contextMenuY)px" @onclick:stopPropagation @oncontextmenu:preventDefault>
      <div class="context-menu-identity" title="@contextAssembly.Path"><strong>@contextAssembly.Name</strong><small>@Path.GetDirectoryName(contextAssembly.Path)</small></div>
      <button disabled="@Workspace.IsBusy" @onclick="UnloadContextAssemblyAsync"><span>Unload assembly</span></button>
    </div>
  }
  @if (settingsOpen)
  {
    <div class="modal-dismiss" @onclick="CloseSettings"></div>
    <section class="settings-dialog" role="dialog" aria-modal="true" aria-labelledby="settings-title">
      <header><strong id="settings-title">Settings</strong><button title="Close settings" aria-label="Close settings" @onclick="CloseSettings">×</button></header>
      <div class="settings-row"><span><strong>Theme</strong><small>Application and code colours</small></span><select class="settings-select" value="@themeId" @onchange="ThemeChangedAsync">@foreach (var theme in Themes.All) { <option value="@theme.Id">@theme.Name</option> }</select></div>
      <div class="settings-row"><span><strong>Application zoom</strong><small>Scale the entire interface</small></span><div class="application-zoom"><button aria-label="Zoom out" disabled="@(zoomPercent <= MinimumZoom)" @onclick="() => ChangeApplicationZoom(-1)">−</button><button class="zoom-percent" aria-label="Reset zoom to 100%" @onclick="ResetApplicationZoom">@zoomPercent%</button><button aria-label="Zoom in" disabled="@(zoomPercent >= MaximumZoom)" @onclick="() => ChangeApplicationZoom(1)">+</button></div></div>
      <label class="settings-row"><span><strong>Debug logging</strong><small>Write detailed diagnostics to the console</small></span><input class="settings-checkbox" type="checkbox" checked="@debugLogging" @onchange="DebugLoggingChanged" /></label>
    </section>
  }
</div>

@code {
  private string query = "";
  private ElementReference explorer;
  private ElementReference searchPanel;
  private IReadOnlySet<NodeId> revealedPath = new HashSet<NodeId>();
  private SymbolId? selectedSymbol;
  private NodeId? selectedNode;
  private Guid? SelectedAssemblyMvid => selectedSymbol?.ModuleMvid ?? Workspace.ActiveTab?.Document.Symbol.ModuleMvid;
  private CancellationTokenSource? saveDelay;
  private CancellationTokenSource? searchDelay;
  private readonly Dictionary<string, CancellationTokenSource> decompilations = [];
  private bool restoring;
  private IReadOnlyList<SearchResult> results = [];
  private bool searchOpen;
  private string searchKind = "All";
  private string searchScope = "All";
  private bool menuOpen;
  private bool settingsOpen;
  private bool focusSearch;
  private bool uiInitializationFailed;
  private ElementReference searchInput;
  private double explorerWidth = 300;
  private double searchPanelHeight = 230;
  private int treeCollapseVersion;
  private int treeSelectionVersion;
  private const int MinimumZoom = 50;
  private const int MaximumZoom = 200;
  private const int ZoomStep = 10;
  private int zoomPercent = 100;
  private string themeId = Themes.DefaultId;
  private bool debugLogging;
  private AssemblyDescriptor? contextAssembly;
  private int contextMenuX;
  private int contextMenuY;
  private DotNetObjectReference<MainWindow>? selfReference;
  private bool sessionRestoreStarted;
  protected override async Task OnInitializedAsync()
  {
    Workspace.Changed += Refresh;
    restoring = true;
    Workspace.SetBusy(true, "Restoring session…");
    try
    {
      await Session.LoadAsync();
      var ui = Session.UiState;
      explorerWidth = Math.Clamp(ui.ExplorerWidth, 190, 1200);
      searchPanelHeight = Math.Clamp(ui.SearchPanelHeight, 120, 900);
      searchOpen = ui.SearchOpen;
      searchKind = ui.SearchKind;
      searchScope = ui.SearchScope;
      zoomPercent = ui.ZoomPercent <= 0 ? 100 : Math.Clamp(ui.ZoomPercent, MinimumZoom, MaximumZoom);
      themeId = Themes.Normalize(ui.ThemeId);
      debugLogging = ui.DebugLogging;
      LoggingSettings.DebugEnabled = debugLogging;
      Zoom.SetZoom(zoomPercent);
    }
    catch (Exception ex) { restoring = false; Workspace.SetBusy(false, $"Session restore failed: {ex.Message}"); }
  }
  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (uiInitializationFailed) return;
    try
    {
      if (firstRender)
      {
        selfReference = DotNetObjectReference.Create(this);
        var storedTheme = await JS.InvokeAsync<string?>("dnSpyXdx.getStoredTheme");
        var restoredFromStorage = !string.IsNullOrWhiteSpace(storedTheme) && Themes.Normalize(storedTheme) != themeId;
        if (restoredFromStorage) themeId = Themes.Normalize(storedTheme);
        await JS.InvokeVoidAsync("dnSpyXdx.applyTheme", themeId);
        await JS.InvokeVoidAsync("dnSpyXdx.initExplorerResize", explorer, selfReference);
        await JS.InvokeVoidAsync("dnSpyXdx.initHistoryButtons", selfReference);
        if (restoredFromStorage) { Session.UiState = CaptureUiState(); ScheduleSave(); StateHasChanged(); }
        if (restoring && !sessionRestoreStarted) { sessionRestoreStarted = true; _ = RestoreWorkspaceAsync(); }
      }
      if (searchOpen) await JS.InvokeVoidAsync("dnSpyXdx.initSearchResize", searchPanel, selfReference);
      if (focusSearch) { focusSearch = false; await searchInput.FocusAsync(); }
    }
    catch (Exception ex) { uiInitializationFailed = true; Workspace.SetBusy(false, $"UI initialization warning: {ex.Message}"); }
  }
  private void Refresh() { InvokeAsync(StateHasChanged); if (!restoring) ScheduleSave(); }
  private async Task RestoreWorkspaceAsync()
  {
    var restored = false;
    try
    {
      await Session.RestoreAssembliesAsync();
      await InvokeAsync(StateHasChanged);
      await Session.RestoreDocumentsAsync();
      if (Workspace.ActiveTab is { } active)
      {
        selectedSymbol = active.Document.Symbol;
        try { revealedPath = (await Backend.GetPathAsync(active.Document.Symbol)).ToHashSet(); }
        catch (Exception ex) { Workspace.SetBusy(true, $"Could not reveal restored document: {ex.Message}"); }
      }
      restored = true;
    }
    catch (Exception ex) { Workspace.SetBusy(true, $"Session restore failed: {ex.Message}"); }
    finally
    {
      restoring = false;
      Workspace.SetBusy(false, restored && Backend.Assemblies.Count > 0 ? "Session restored" : restored ? "Ready" : "Session restore skipped");
      await InvokeAsync(StateHasChanged);
    }
  }
  private void ScheduleSave() { saveDelay?.Cancel(); saveDelay?.Dispose(); saveDelay = new CancellationTokenSource(); var token = saveDelay.Token; _ = SaveAfterDelayAsync(token); }
  private UiSessionState CaptureUiState() => new(explorerWidth, searchPanelHeight, searchOpen, searchKind, searchScope, zoomPercent, themeId, debugLogging);
  private async Task SaveAfterDelayAsync(CancellationToken token) { try { await Task.Delay(350, token); Session.UiState = CaptureUiState(); await Session.SaveAsync(token); } catch (OperationCanceledException) { } }
  private async Task OpenAsync() { var path = await Dialogs.OpenAssemblyAsync(); if (path is null) return; Workspace.SetBusy(true, "Opening assembly…"); try { await Backend.OpenAsync(path); Workspace.SetBusy(false, $"Opened {Path.GetFileName(path)}"); } catch (Exception ex) { Workspace.SetBusy(false, ex.Message); } }
  private void ToggleMenu() => menuOpen = !menuOpen;
  private void CloseMenu() => menuOpen = false;
  private void OpenSettings() { menuOpen = false; settingsOpen = true; }
  private void CloseSettings() => settingsOpen = false;
  private async Task Exit()
  {
    menuOpen = false;
    Session.UiState = CaptureUiState();
    await Session.SaveAsync();
    ApplicationLifetime.Exit();
  }
  private async Task OpenFromMenuAsync() { menuOpen = false; await OpenAsync(); }
  private async Task ExportFromMenuAsync() { menuOpen = false; await ExportAsync(); }
  private void OpenSearchPanel() { menuOpen = false; searchOpen = true; focusSearch = true; ScheduleSave(); StateHasChanged(); }
  private void ToggleSearchPanel() { if (searchOpen) CloseSearch(); else OpenSearchPanel(); }
  private async Task UnloadAllAsync() { menuOpen = false; CancelAllDecompilations(); Workspace.SetBusy(true, "Unloading assemblies…"); foreach (var assembly in Backend.Assemblies.ToArray()) await Backend.CloseAsync(assembly.SessionId); Workspace.Clear(); SourceViewStates.Clear(); SourceCache.Clear(); results = []; query = ""; searchOpen = false; selectedSymbol = null; selectedNode = null; revealedPath = new HashSet<NodeId>(); Workspace.SetBusy(false, "All assemblies unloaded"); }
  private void OpenAssemblyContextMenu(MouseEventArgs e, AssemblyDescriptor assembly)
  {
    menuOpen = false;
    contextAssembly = assembly;
    contextMenuX = (int)Math.Round(e.ClientX);
    contextMenuY = (int)Math.Round(e.ClientY);
  }
  private void CloseAssemblyContextMenu() => contextAssembly = null;
  private async Task UnloadContextAssemblyAsync()
  {
    if (contextAssembly is not { } assembly || Workspace.IsBusy) return;
    contextAssembly = null;
    Workspace.SetBusy(true, $"Unloading {assembly.Name}…");
    foreach (var tab in Workspace.Tabs.Where(tab => tab.Document.Symbol.ModuleMvid == assembly.ModuleMvid).ToArray())
    {
      if (decompilations.TryGetValue(tab.Id, out var cancellation)) await cancellation.CancelAsync();
    }
    await Backend.CloseAsync(assembly.SessionId);
    Workspace.CloseAssembly(assembly.ModuleMvid);
    SourceViewStates.RemoveAssembly(assembly.ModuleMvid);
    SourceCache.RemoveAssembly(assembly.ModuleMvid);
    results = results.Where(result => result.Symbol.ModuleMvid != assembly.ModuleMvid).ToArray();
    if (selectedNode?.SessionId == assembly.SessionId) selectedNode = null;
    if (selectedSymbol?.ModuleMvid == assembly.ModuleMvid)
    {
      selectedSymbol = Workspace.ActiveTab?.Document.Symbol;
      revealedPath = selectedSymbol is { } symbol ? (await Backend.GetPathAsync(symbol)).ToHashSet() : new HashSet<NodeId>();
    }
    Workspace.SetBusy(false, $"Unloaded {assembly.Name}");
  }
  private async Task OpenSymbolAsync(SymbolId symbol, bool newTab = false, string? displayName = null, bool isType = false, SymbolId? focusSymbol = null)
  {
    selectedSymbol = symbol;
    selectedNode = null;
    var assemblyName = Backend.Assemblies.FirstOrDefault(a => a.ModuleMvid == symbol.ModuleMvid)?.Name ?? "Assembly";
    if (!newTab && Workspace.ActiveTab is { IsLoading: true } loadingTab) CancelDecompilation(loadingTab.Id);
    if (isType || IsTypeSymbol(symbol))
    {
      var tabId = Workspace.OpenLoading(symbol, displayName ?? "Type", assemblyName, newTab);
      var cancellation = new CancellationTokenSource();
      decompilations[tabId] = cancellation;
      _ = DecompileTypeIntoTabAsync(tabId, symbol, focusSymbol, cancellation);
      return;
    }
    Workspace.SetBusy(true, "Decompiling…");
    try { var doc = await Backend.DecompileAsync(symbol); Workspace.Open(doc, assemblyName, newTab); Workspace.SetBusy(false, $"Decompiled {doc.Title}"); }
    catch (Exception ex) { Workspace.SetBusy(false, ex.Message); }
  }
  private Task OpenTreeSymbolAsync(NavigationRequest request) => OpenSymbolAsync(request.Symbol, request.NewTab || Workspace.Tabs.Count == 0, request.DisplayName, request.Kind == TreeNodeKind.Type);
  private async Task OpenReferenceAsync(NodeId reference) { Workspace.SetBusy(true, "Loading reference…"); try { var assembly = await Backend.OpenReferenceAsync(reference); revealedPath = new HashSet<NodeId> { assembly.RootNode }; selectedSymbol = null; selectedNode = assembly.RootNode; treeSelectionVersion++; Workspace.SetBusy(false, $"Opened {assembly.Name}"); StateHasChanged(); } catch (Exception ex) { Workspace.SetBusy(false, ex.Message); } }
  private async Task OpenSearchResultAsync(SearchResult result, bool newTab)
  {
    revealedPath = (await Backend.GetPathAsync(result.DeclaringType)).ToHashSet();
    selectedSymbol = result.DeclaringType;
    selectedNode = null;
    treeSelectionVersion++;
    await OpenSymbolAsync(result.DeclaringType, newTab || Workspace.Tabs.Count == 0, result.Kind == "Type" ? result.Name : null, true, result.Kind == "Type" ? null : result.Symbol);
    StateHasChanged();
  }
  private async Task NavigateFromSourceAsync(NavigationRequest request)
  {
    var declaringType = await Backend.GetDeclaringTypeAsync(request.Symbol);
    revealedPath = (await Backend.GetPathAsync(declaringType)).ToHashSet();
    selectedSymbol = declaringType;
    selectedNode = null;
    treeSelectionVersion++;
    await OpenSymbolAsync(declaringType, request.NewTab, IsTypeSymbol(request.Symbol) ? request.DisplayName : null, true, IsTypeSymbol(request.Symbol) ? null : request.Symbol);
    StateHasChanged();
  }
  private void TabMouseUp(MouseEventArgs e, string id) { if (e.Button == 1) CloseTab(id); }
  private static bool IsTypeSymbol(SymbolId symbol) => (symbol.MetadataToken >> 24) == 0x02;
  private async Task DecompileTypeIntoTabAsync(string tabId, SymbolId symbol, SymbolId? focusSymbol, CancellationTokenSource cancellation)
  {
    var token = cancellation.Token;
    try
    {
      var document = await Backend.DecompileAsync(symbol, token);
      if (focusSymbol is not null) document = document with { FocusSymbol = focusSymbol };
      token.ThrowIfCancellationRequested();
      await InvokeAsync(() =>
      {
        if (!IsCurrentDecompilation(tabId, cancellation)) return;
        Workspace.CompleteLoading(tabId, document);
        Workspace.SetBusy(false, $"Decompiled {document.Title}");
      });
    }
    catch (OperationCanceledException) { }
    catch (Exception ex) { await InvokeAsync(() => { if (IsCurrentDecompilation(tabId, cancellation)) { Workspace.FailLoading(tabId, ex.Message); Workspace.SetBusy(false, ex.Message); } }); }
    finally
    {
      if (IsCurrentDecompilation(tabId, cancellation)) decompilations.Remove(tabId);
      cancellation.Dispose();
    }
  }
  private bool IsCurrentDecompilation(string tabId, CancellationTokenSource cancellation) => decompilations.TryGetValue(tabId, out var current) && ReferenceEquals(current, cancellation);
  private void CancelDecompilation(string tabId)
  {
    if (!decompilations.Remove(tabId, out var cancellation)) return;
    cancellation.Cancel();
  }
  private void CloseTab(string id)
  {
    var wasDecompiling = decompilations.TryGetValue(id, out var cancellation);
    if (cancellation is not null) _ = cancellation.CancelAsync();
    SourceViewStates.RemoveTab(id);
    Workspace.Close(id);
    if (wasDecompiling) Workspace.SetBusy(false, "Decompilation cancelled");
  }
  private void CancelAllDecompilations() { foreach (var cancellation in decompilations.Values) { cancellation.Cancel(); cancellation.Dispose(); } decompilations.Clear(); }
  [JSInvokable] public async Task NavigateHistory(bool forward)
  {
    if (!(forward ? Workspace.GoForward() : Workspace.GoBack())) return;
    if (Workspace.ActiveTab is not { } tab) return;
    selectedSymbol = tab.Document.Symbol;
    revealedPath = (await Backend.GetPathAsync(tab.Document.Symbol)).ToHashSet();
    StateHasChanged();
  }
  private void QueueSearch() { searchDelay?.Cancel(); searchDelay?.Dispose(); searchDelay = new CancellationTokenSource(); _ = SearchAfterDelayAsync(searchDelay.Token); }
  private async Task SearchAfterDelayAsync(CancellationToken token) { try { await Task.Delay(500, token); await RunSearchAsync(token); } catch (OperationCanceledException) { } }
  private async Task SearchAsync() { searchDelay?.Cancel(); searchDelay?.Dispose(); searchDelay = new CancellationTokenSource(); try { await RunSearchAsync(searchDelay.Token); } catch (OperationCanceledException) { } }
  private async Task RunSearchAsync(CancellationToken token) { var found = await Backend.SearchAsync(query, token); token.ThrowIfCancellationRequested(); var selectedMvid = SelectedAssemblyMvid; results = found.Where(r => searchKind == "All" || r.Kind == searchKind).Where(r => searchScope == "All" || selectedMvid is not null && r.Symbol.ModuleMvid == selectedMvid).ToArray(); searchOpen = true; StateHasChanged(); }
  private void CloseSearch() { searchOpen = false; ScheduleSave(); StateHasChanged(); }
  private void LayoutOptionChanged() => ScheduleSave();
  private async Task DebugLoggingChanged(ChangeEventArgs e)
  {
    debugLogging = e.Value is true;
    LoggingSettings.DebugEnabled = debugLogging;
    Session.UiState = CaptureUiState();
    await Session.SaveAsync();
  }
  private async Task ThemeChangedAsync(ChangeEventArgs e)
  {
    themeId = Themes.Normalize(e.Value?.ToString());
    await JS.InvokeVoidAsync("dnSpyXdx.applyTheme", themeId);
    Session.UiState = CaptureUiState();
    await Session.SaveAsync();
  }
  private void CollapseAllNodes() => treeCollapseVersion++;
  [JSInvokable] public void ExplorerResized(double width) { explorerWidth = width; ScheduleSave(); }
  [JSInvokable] public void SearchPanelResized(double height) { searchPanelHeight = height; ScheduleSave(); }
  private void ChangeApplicationZoom(int direction)
  {
    var next = Math.Clamp(zoomPercent + Math.Sign(direction) * ZoomStep, MinimumZoom, MaximumZoom);
    if (next == zoomPercent) return;
    zoomPercent = next;
    Zoom.SetZoom(zoomPercent);
    ScheduleSave();
    StateHasChanged();
  }
  private void ResetApplicationZoom()
  {
    if (zoomPercent == 100) return;
    zoomPercent = 100;
    Zoom.SetZoom(zoomPercent);
    ScheduleSave();
    StateHasChanged();
  }
  private async Task SearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") await SearchAsync(); }
  private async Task ExportAsync()
  {
    var folder = await Dialogs.SelectExportFolderAsync();
    if (folder is null) return;
    Workspace.SetBusy(true, "Preparing solution extraction…");
    var progress = new Progress<ExportProgress>(update =>
    {
      if (update.Total <= 0) Workspace.SetBusy(true, update.Message);
      else
      {
        var completed = Math.Clamp(update.Completed, 0, update.Total);
        var percentage = (int)Math.Round(completed * 100d / update.Total);
        Workspace.SetBusy(true, $"{percentage}% · {completed}/{update.Total} files — {update.Message}");
      }
    });
    try
    {
      // WholeProjectDecompiler is synchronous and CPU-heavy. Running the export pipeline on a
      // worker thread lets the native folder dialog close and keeps status updates repainting.
      var request = new ExportRequest(Backend.Assemblies.Select(a => a.SessionId).ToArray(), folder);
      var report = await Task.Run(() => Exporter.ExportAsync(request, progress));
      var message = report.Success
        ? report.Warnings.Count == 0 ? $"Solution extracted to {folder}" : $"Solution extracted with {report.Warnings.Count} warning(s) to {folder}"
        : $"Solution extraction completed with warnings; see {Path.Combine(folder, "export-report.json")}";
      Workspace.SetBusy(false, message);
    }
    catch (Exception ex) { Workspace.SetBusy(false, $"Solution extraction failed: {ex.Message}"); }
  }
  public void Dispose() { Workspace.Changed -= Refresh; saveDelay?.Cancel(); saveDelay?.Dispose(); searchDelay?.Cancel(); searchDelay?.Dispose(); CancelAllDecompilations(); selfReference?.Dispose(); }
}
